#!/bin/bash
#
# post-push 훅 — push 직후 자동으로 실행됨
# setup-hooks.sh 를 한 번 실행하면 .git/hooks/post-push 에 심볼릭 링크가 생성됨

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

# main 브랜치나 detached HEAD는 건너뜀
if [ "$BRANCH" = "main" ] || [ -z "$BRANCH" ]; then
  exit 0
fi

# claude CLI가 설치되어 있는지 확인
if ! command -v claude &>/dev/null; then
  echo "⚠️  claude CLI를 찾을 수 없습니다. Claude Code가 설치되어 있는지 확인해주세요."
  exit 0
fi

# gh CLI가 설치되어 있는지 확인
if ! command -v gh &>/dev/null; then
  echo "⚠️  gh CLI를 찾을 수 없습니다. GitHub CLI를 설치해주세요."
  exit 0
fi

echo ""
echo "🤖 Claude 코드리뷰 파이프라인 시작 (브랜치: $BRANCH)"
echo ""

# Claude Code CLI로 전체 워크플로우 실행
# --allowedTools Bash: gh, git 명령어 실행 허용
# -p: non-interactive 모드 (사용자 입력 없이 자동 실행)
claude -p "
브랜치 '${BRANCH}'에 push가 발생했습니다. 아래 워크플로우를 순서대로 실행해주세요.

---

## 1단계 — PR 존재 여부 확인

아래 명령어로 이 브랜치에 열린 PR이 있는지 확인합니다.

\`\`\`
gh pr list --head \"${BRANCH}\" --base main --state open --json number,title
\`\`\`

- 결과가 비어있으면 → 2단계(PR 생성)로 이동
- PR이 있으면 → 3단계(코드리뷰)로 이동

---

## 2단계 — PR 생성 (PR이 없을 때만)

main 대비 변경사항을 확인합니다.

\`\`\`
git diff origin/main...HEAD
\`\`\`

변경사항을 분석해서 PR 제목과 본문을 작성합니다.

**제목 규칙:**
- 형식: \`feat | fix | refactor | chore | docs: 한국어 요약\`
- 예시: \`feat: 다이어리 생성 폼 및 Supabase 저장 로직 추가\`
- 브랜치명(${BRANCH})과 변경 내용을 종합해서 판단

**본문 형식:**
\`\`\`
## 작업 내용
(핵심 변경 목적 1~2줄)

## 주요 변경 사항
- (파일/기능 단위로)

## 체크리스트
- [ ] 테스트 완료
- [ ] 린트 통과
- [ ] 타입 오류 없음
\`\`\`

PR을 생성합니다.

\`\`\`
gh pr create --title \"[생성한 제목]\" --body \"[생성한 본문]\" --base main --head \"${BRANCH}\"
\`\`\`

---

## 3단계 — 코드리뷰

### 3-1. PR 번호 확인

\`\`\`
gh pr list --head \"${BRANCH}\" --base main --state open --json number --jq '.[0].number'
\`\`\`

### 3-2. 이전 Claude 리뷰 확인

아래 명령어로 Claude가 이전에 작성한 리뷰가 있는지 확인합니다.
Claude 리뷰는 본문에 \`<!-- claude-review -->\` 마커가 포함되어 있습니다.

\`\`\`
REPO=\$(gh repo view --json nameWithOwner -q .nameWithOwner)
gh api \"repos/\$REPO/pulls/[PR번호]/reviews\" --jq '[.[] | select(.body | contains(\"<!-- claude-review -->\"))] | last // empty'
\`\`\`

- 이전 리뷰가 없으면 → 전체 diff 리뷰: \`gh pr diff [PR번호]\`
- 이전 리뷰가 있으면 → 해당 리뷰의 \`commit_id\` 이후 변경사항만 리뷰: \`git diff [commit_id]..HEAD\`

### 3-3. 코드리뷰 진행

**프로젝트 정보:**
- Next.js 14 (App Router) + TypeScript + Tailwind CSS
- Supabase (인증 + DB)
- Feature-Sliced Design 아키텍처: app → widgets → features → entities → shared (단방향 엄수)
- 같은 레이어 간 import 절대 금지 (예: feature → feature)
- React 19, Mapbox GL, react-hook-form

**심각도 기준:**
- **CRITICAL**: 보안 취약점(XSS/SQL Injection 등), 민감 정보 노출, 데이터 손실 위험, 서비스 중단 가능성, 심각한 로직 오류 → 머지 불가, 반드시 수정
- **MINOR**: FSD 아키텍처 위반, 잠재적 버그, 성능 문제, 코드 품질 저하 → 수정 권장, 머지 가능
- **APPROVED**: 이슈 없음 또는 SUGGESTION만 있음 → 즉시 머지 가능

재리뷰인 경우 이전 이슈들이 해결되었는지 중점적으로 확인합니다.

---

## 4단계 — 리뷰 결과를 GitHub PR에 반영

리뷰 결과에 따라 아래 중 하나를 실행합니다.

### CRITICAL인 경우

\`\`\`
gh pr review [PR번호] --request-changes --body \"[아래 형식의 리뷰 내용]\"
\`\`\`

### MINOR인 경우

\`\`\`
gh pr comment [PR번호] --body \"[아래 형식의 리뷰 내용]\"
\`\`\`

### APPROVED인 경우

\`\`\`
gh pr comment [PR번호] --body \"[아래 형식의 리뷰 내용]\"
gh pr merge [PR번호] --rebase --delete-branch --yes
\`\`\`

**리뷰 댓글 형식** (반드시 이 형식을 지킬 것):
\`\`\`
<!-- claude-review -->
## [심각도에 따른 이모지 + 제목]
🚨 CRITICAL — 머지 불가  /  ⚠️ MINOR — 개선 필요  /  ✅ APPROVED — 승인

[종합 평가 요약]

---

[이슈가 있을 경우 목록]
### 🔴/🟡/🔵 [CRITICAL/WARNING/SUGGESTION] \`파일경로\`
이슈 내용
> 💡 수정 제안 (있을 경우)

---

[MINOR인 경우에만 추가]
> 나중에 수정하려면 댓글에 \`/merge\`를 입력하면 머지됩니다.
> 예: \`이건 다음에 수정하겠습니다 /merge\`

_이 리뷰는 Claude가 자동으로 작성했습니다._
\`\`\`
" --allowedTools "Bash" 2>&1

echo ""
echo "✅ 완료"
echo ""
